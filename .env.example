# คัดลอกไฟล์นี้เป็น .env แล้วแก้ค่าตามจริง
# ----------------------------------------------------

# การเชื่อมต่อ PostgreSQL (เลือกใช้ DATABASE_URL อย่างเดียวก็พอ)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/bla_policy

# พอร์ตของ API server
PORT=3000

# เปิด SSL ตอนต่อ DB (Render/Cloud ส่วนใหญ่ต้องเป็น true, local เป็น false)
PGSSL=false
